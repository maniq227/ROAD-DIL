!**/optimal_output/runs/val_batch0_pred.jpg
!**/optimal_output/runs/train_batch0.jpg
!**/optimal_output/runs/args.yaml

# Still exclude in-run weights
**/optimal_output/runs/weights/

# Allow keeping lightweight metrics under per-strategy optimal_output
!YOLO-ER/optimal_output/continual_eval_matrix.json
!YOLO-ER/optimal_output/continual_learning_metrics.json
!YOLO-ER/optimal_output/standard_metrics.json
!YOLO-ER/optimal_output/analysis_extended_ap/*.json
!YOLO-ER/optimal_output/continual_eval_matrix.csv

!YOLO-GDUMB/optimal_output/continual_eval_matrix.json
!YOLO-GDUMB/optimal_output/continual_learning_metrics.json
